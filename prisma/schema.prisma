generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

model Client {
  id         String   @id @default(cuid())
  name       String
  company    String?
  whatsapp   String?
  email      String?
  segment    String?
  leadSource String?
  status     String   @default("lead")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  deals      Deal[]
  proposals  Proposal[]
  contracts  Contract[]
  tasks      Task[]
  activities Activity[]
}

model Deal {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceType    String
  estimatedValue Float
  stage          String   @default("lead_novo")
  lastActivityAt DateTime @default(now())
  stageEnteredAt DateTime @default(now())
  lostReason     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proposal   Proposal?
  activities Activity[]
  tasks      Task[]
}

model Proposal {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dealId       String?  @unique
  deal         Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  title        String
  serviceType  String
  summary      String?
  scope        String?
  timeline     String?
  investment   Float?
  paymentTerms String?
  status       String   @default("rascunho")
  version      Int      @default(1)
  shareToken   String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Contract {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service      String
  type         String
  monthlyValue Float?
  totalValue   Float?
  startDate    DateTime
  endDate      DateTime?
  status       String    @default("ativo")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  payments Payment[]
}

model Payment {
  id         String    @id @default(cuid())
  contractId String
  contract   Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  amount     Float
  dueDate    DateTime
  status     String    @default("pendente")
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
}

model Task {
  id        String   @id @default(cuid())
  title     String
  type      String
  priority  String   @default("media")
  dueDate   DateTime
  completed Boolean  @default(false)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  automated Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  content   String
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}
